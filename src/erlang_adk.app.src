{application, erlang_adk, [
    {description, "An OTP-native Agent Development Kit for Erlang."},
    {tags, ["agents", "adk", "otp", "llm", "erlang"]},
    {vsn, "0.5.0"},
    {registered, []},
    {mod, {erlang_adk_app, []}},
    {applications, [
        kernel,
        stdlib,
        crypto,
        inets,
        ssl,
        public_key,
        cowboy,
        telemetry,
        jsx,
        gun,
        oidcc
    ]},
    {env, [
        {a2a_enabled, false},
        {a2a_v1_enabled, false},
        {dev_enabled, false},
        {memory_outbox_enabled, false},
        {memory_outbox_options, #{}},
        {dev_sse_max_events, 128},
        {dev_sse_max_bytes, 1048576},
        {dev_sse_max_duration_ms, 300000},
        {dev_max_resource_results, 100},
        {dev_diagnostic_timeout_ms, 5000},
        {dev_diagnostic_context_policy,
         #{max_bytes => 1048576,
           max_tokens => 262144,
           overflow => truncate}},
        {agent_turn_timeout, 60000},
        {max_concurrent_invocations, 32},
        {agent_config_retention_ms, 60000},
        {callback_timeout_ms, 5000},
        {callback_max_heap_words, 262144},
        {ambient_runtime, #{max_triggers => 64, max_events => 10000}},
        {ambient_max_sources, 64},
        {admission_control,
         #{global_limit => 1024,
           default_agent_limit => 64,
           overflow => reject,
           max_queue => 1024,
           default_queue_timeout => 30000}},
        {oidc_providers, []},
        {oidc_max_clock_skew_seconds, 300}
    ]},
    {modules, []},

    {licenses, ["Apache-2.0"]},
    {links, [{"GitHub", "https://github.com/hsalap7/erlang_adk"}]}
]}.
