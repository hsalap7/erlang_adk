   [kernel,
    stdlib,
    inets,
    ssl,
    cowboy,
    telemetry,
    mnesia,
    jsx
   ]},
  {env,[]},
  {modules, []},

  {licenses, ["Apache-2.0"]},
  {links, [{"GitHub", "https://github.com/google/erlang_adk"}]}
 ]}.
