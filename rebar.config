{erl_opts, [debug_info]}.
{deps, [
    {jsx, "~> 3.1"},
    {cowboy, "2.12.0"},
    {telemetry, "1.3.0"}
]}.

{shell, [
    % {config, "config/sys.config"},
    {apps, [erlang_adk]}
]}.

{plugins, [rebar3_hex]}.

{project_plugins, [rebar3_ex_doc]}.

{hex, [{doc, ex_doc}]}.

{ex_doc, [
    {source_url, <<"https://github.com/hsalap7/erlang_adk">>},
    {extras, [<<"README.md">>]},
    {main, <<"readme">>}
]}.
